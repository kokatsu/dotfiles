#!/bin/bash
# Open URLs/files in Windows default application from WSL
# Replaces wslview to avoid PowerShell Constrained Language Mode errors
[ -z "$1" ] && exit 1
# The empty "" fills start's window-title slot; without it a quoted
# (space-containing) argument is consumed as the title and nothing opens
cmd.exe /c start "" "${1//&/^&}" 2>/dev/null
