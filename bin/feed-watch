#!/bin/bash
set -euo pipefail

# feed-watch: フィードの更新を監視し、WezTerm ステータスバーに表示する
# フィードリストは bulletty の OPML ファイルから読み込む
#
# Usage:
#   feed-watch check          - 全フィードをチェックし status.json を更新
#   feed-watch read [<name>]  - 指定フィード (または全フィード) を既読にする

OPML_DIR="$HOME/.config/bulletty"

# --- Windows 側の出力先を決定 ---
get_status_dir() {
  local winuser
  # cmd.exe は systemd サービス内では WSL interop が無効で使えない
  winuser=$(/mnt/c/Windows/System32/cmd.exe /C "echo %USERNAME%" 2>/dev/null | tr -d '\r') || true
  if [[ -n "$winuser" && -d "/mnt/c/Users/$winuser" ]]; then
    echo "/mnt/c/Users/$winuser/.cache/feed-watch"
    return
  fi

  # Fallback: /mnt/c/Users からシステム以外のディレクトリを探す
  local d base
  for d in /mnt/c/Users/*/; do
    base=$(basename "$d")
    case "$base" in
      Public|Default|"Default User"|"All Users") continue ;;
    esac
    echo "${d}.cache/feed-watch"
    return
  done

  return 1
}

STATUS_DIR=$(get_status_dir) || { echo "Windows mount not available, skipping." >&2; exit 0; }
STATUS_FILE="$STATUS_DIR/status.json"

ensure_status_file() {
  mkdir -p "$STATUS_DIR"
  if [[ ! -f "$STATUS_FILE" ]]; then
    echo '{"feeds":{}}' > "$STATUS_FILE"
  fi
}

# --- 共通: 新規エントリを数えて status を更新 ---
# $1: status JSON, $2: フィード名, $3: IDs (改行区切り), $4: type (github|feed), $5: url, $6: category
update_feed_status() {
  local status="$1" name="$2" ids="$3" type="$4" url="$5" category="$6"

  if [[ -z "$ids" ]]; then
    # 既存エントリがあれば category だけ更新
    echo "$status" | jq \
      --arg name "$name" --arg category "$category" \
      'if .feeds[$name] then .feeds[$name].category = $category else . end'
    return
  fi

  local latest_id
  latest_id=$(echo "$ids" | head -n1)

  local prev_id
  prev_id=$(echo "$status" | jq -r --arg name "$name" '.feeds[$name].last_seen_id // ""')

  local prev_unread
  prev_unread=$(echo "$status" | jq -r --arg name "$name" '.feeds[$name].unread_count // 0')

  # 既存の last_summarized_id を保持 (上書きしない)
  local prev_summarized
  prev_summarized=$(echo "$status" | jq -r --arg name "$name" '.feeds[$name].last_summarized_id // ""')

  if [[ -z "$prev_id" ]]; then
    # 初回: 未読 0 で最新 ID を記録
    echo "$status" | jq \
      --arg name "$name" --arg id "$latest_id" --arg type "$type" --arg url "$url" --arg category "$category" \
      '.feeds[$name] = {"last_seen_id": $id, "unread_count": 0, "type": $type, "url": $url, "category": $category}'
  elif [[ "$prev_id" == "$latest_id" ]]; then
    # 変更なし (url, category は常に最新化)
    echo "$status" | jq \
      --arg name "$name" --arg url "$url" --arg category "$category" \
      '.feeds[$name].url = $url | .feeds[$name].category = $category'
  else
    # 新規エントリを数える
    local new_count=0
    while IFS= read -r id; do
      if [[ "$id" == "$prev_id" ]]; then
        break
      fi
      ((new_count++))
    done <<< "$ids"

    local total_unread=$(( prev_unread + new_count ))

    echo "$status" | jq \
      --arg name "$name" --arg id "$latest_id" --arg type "$type" --arg url "$url" --arg category "$category" \
      --arg summarized "$prev_summarized" \
      --argjson count "$total_unread" \
      '.feeds[$name] = {"last_seen_id": $id, "unread_count": $count, "type": $type, "url": $url, "category": $category}
      | if $summarized != "" then .feeds[$name].last_summarized_id = $summarized else . end'
  fi
}

# --- フィードからエントリ ID を取得 (Atom/RSS 自動判別) ---
fetch_feed_ids() {
  local url="$1"
  local content
  content=$(curl -sfL "$url") || return 1

  # Atom: <id> タグ (先頭のフィード自体の id はスキップ)
  local atom_ids
  atom_ids=$(echo "$content" | grep -o '<id>[^<]*</id>' | sed 's/<id>\(.*\)<\/id>/\1/' | tail -n +2)
  if [[ -n "$atom_ids" ]]; then
    echo "$atom_ids"
    return
  fi

  # RSS: <guid> タグ
  echo "$content" | grep -oP '<guid[^>]*>\K[^<]+' || true
}

# --- OPML パース: "category|name|xmlUrl|htmlUrl" 行を出力 ---
parse_opml() {
  local files=()
  local f
  for f in "$OPML_DIR"/feeds*.opml; do
    [[ -f "$f" ]] || continue
    files+=("$f")
  done

  if [[ ${#files[@]} -eq 0 ]]; then
    return
  fi

  awk '
    function extract(attr, line,    pat, s, e) {
      pat = attr "=\"[^\"]*\""
      if (match(line, pat)) {
        s = RSTART + length(attr) + 2
        e = RLENGTH - length(attr) - 3
        return substr(line, s, e)
      }
      return ""
    }
    /<outline/ && /xmlUrl=/ {
      name = extract("text", $0)
      xml_url = extract("xmlUrl", $0)
      html_url = extract("htmlUrl", $0)
      if (html_url == "") html_url = xml_url
      print category "|" name "|" xml_url "|" html_url
      next
    }
    /<outline/ && !/\/>/ {
      t = extract("text", $0)
      if (t != "") category = t
    }
    /<\/outline>/ {
      # bulletty の OPML は 2 階層なので、閉じタグでカテゴリをリセットしても
      # 次のカテゴリ outline で上書きされる。明示的なリセットは不要。
    }
  ' "${files[@]}"
}

# --- check サブコマンド ---
cmd_check() {
  ensure_status_file

  if ! compgen -G "$OPML_DIR/feeds*.opml" > /dev/null; then
    echo "No OPML files matching $OPML_DIR/feeds*.opml" >&2
    exit 1
  fi

  local status
  status=$(cat "$STATUS_FILE")

  while IFS='|' read -r category name xml_url html_url; do
    local ids

    # GitHub フィード: gh api でコミットSHA を取得
    if [[ "$xml_url" =~ ^https://github\.com/([^/]+/[^/]+)/commits\.atom$ ]]; then
      local repo="${BASH_REMATCH[1]}"
      ids=$(gh api "repos/$repo/commits?per_page=100" --jq '.[].sha' 2>/dev/null) || {
        echo "Failed to fetch commits for $repo" >&2
        continue
      }
      status=$(update_feed_status "$status" "$name" "$ids" "github" "$html_url" "$category")
    else
      ids=$(fetch_feed_ids "$xml_url" 2>/dev/null) || {
        echo "Failed to fetch feed: $name" >&2
        continue
      }
      status=$(update_feed_status "$status" "$name" "$ids" "feed" "$html_url" "$category")
    fi
  done < <(parse_opml)

  echo "$status" | jq --argjson ts "$(date +%s)" '.last_updated = $ts' > "$STATUS_FILE"
}

# --- read サブコマンド ---
cmd_read() {
  ensure_status_file

  local target="${1:-}"
  local status
  status=$(cat "$STATUS_FILE")

  if [[ -z "$target" ]]; then
    # 全フィード既読
    status=$(echo "$status" | jq '.feeds |= with_entries(.value.unread_count = 0)')
  else
    # 部分一致で検索
    local matched
    matched=$(echo "$status" | jq -r --arg t "$target" \
      '[.feeds | keys[] | select(contains($t))] | .[0] // ""')

    if [[ -z "$matched" ]]; then
      echo "No feed matching '$target'" >&2
      exit 1
    fi

    status=$(echo "$status" | jq --arg name "$matched" \
      '.feeds[$name].unread_count = 0')
  fi

  echo "$status" | jq . > "$STATUS_FILE"
}

# --- メイン ---
case "${1:-}" in
  check) cmd_check ;;
  read)  cmd_read "${2:-}" ;;
  *)
    echo "Usage: feed-watch {check|read [<name>]}" >&2
    exit 1
    ;;
esac
