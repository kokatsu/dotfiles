# Dotfiles repository-local commands.
prefix_rule(
    pattern = ["just", ["check", "fmt", "nvim-test"]],
    decision = "allow",
    justification = "Allow this trusted repository's standard check, format, and Neovim test recipes without prompting.",
    match = [
        "just check",
        "just fmt",
        "just nvim-test",
    ],
    not_match = [
        "just deploy",
        "just test",
    ],
)

prefix_rule(
    pattern = ["nix", "flake", ["metadata", "show"]],
    decision = "allow",
    justification = "Allow read-only flake inspection for this trusted dotfiles repository.",
    match = [
        "nix flake metadata",
        "nix flake show",
    ],
    not_match = [
        "nix flake update",
        "nix flake lock --update-input nixpkgs",
    ],
)
