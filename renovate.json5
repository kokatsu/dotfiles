{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  labels: [
    'dependencies',
  ],
  minimumReleaseAge: '1 day',
  ignorePaths: [
    'nix/npm-locks/**',
  ],
  gitIgnoredAuthors: [
    'github-actions[bot]@users.noreply.github.com',
  ],
  customDatasources: {
    "claude-code": {
      defaultRegistryUrlTemplate: "https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases/latest",
      format: "plain",
    },
  },
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/nix/overlays/[\\w-]+\\.nix$/',
      ],
      matchStrings: [
        '#\\s*Renovate:\\s*datasource=(?<datasource>[\\w.-]+)\\s+depName=(?<depName>[\\w@/-]+)\\n\\s+[\\w-]+\\s*=\\s*_?final:\\s*prev:\\s*let\\n\\s+version\\s*=\\s*"(?<currentValue>[^"]+)"',
        '#\\s*Renovate:\\s*datasource=(?<datasource>[\\w.-]+)\\s+depName=(?<depName>[\\w@/-]+)\\n\\s+[\\w-]+\\s*=\\s*_final:\\s*prev:\\s*\\{\\n\\s+[\\w-]+\\s*=\\s*prev\\.[\\w.]+\\s+(?:rec\\s)?\\{\\n\\s+pname\\s*=\\s*"[^"]+";\\n\\s+version\\s*=\\s*"(?<currentValue>[^"]+)"',
        '#\\s*Renovate:\\s*datasource=(?<datasource>[\\w.-]+)\\s+depName=(?<depName>[\\w@/-]+)\\n\\s+[\\w-]+\\s*=\\s*mk\\w+\\s+(?:rec\\s)?\\{\\n\\s+pname\\s*=\\s*"[^"]+";\\n\\s+version\\s*=\\s*"(?<currentValue>[^"]+)"',
      ],
      versioningTemplate: 'semver',
    },
    {
      // flake.nix のリリースタグ pin 用 (例: url = "github:owner/repo/v1.2.3")
      customType: 'regex',
      managerFilePatterns: [
        '/^flake\\.nix$/',
      ],
      matchStrings: [
        '#\\s*Renovate:\\s*datasource=(?<datasource>[\\w.-]+)\\s+depName=(?<depName>[\\w./-]+)\\s*\\n\\s+[\\w-]+\\s*=\\s*\\{\\s*\\n\\s+url\\s*=\\s*"github:[\\w./-]+/(?<currentValue>[^"]+)"',
      ],
      versioningTemplate: 'semver',
    },
  ],
  packageRules: [
    {
      matchDatasources: [
        'npm',
      ],
      minimumReleaseAge: '7 days',
    },
    {
      matchFileNames: [
        'nix/overlays/*.nix',
      ],
      semanticCommitType: 'build',
      semanticCommitScope: 'deps',
    },
    {
      // overlays では version 文字列を tag prefix なしで保持しているため strip する
      // biomejs/biome の GitHub release tag は @biomejs/biome@2.4.16 形式
      // flake.nix のタグ pin (例: url = ".../v1.2.3") には適用しない (URL ref に 'v' が必要)
      matchDatasources: [
        'github-releases',
      ],
      matchFileNames: [
        'nix/overlays/*.nix',
      ],
      extractVersion: '^(?:rust-v|v|@biomejs/biome@)?(?<version>.*)$',
    },
    {
      matchManagers: [
        'github-actions',
      ],
      minimumReleaseAge: '7 days',
      internalChecksFilter: 'strict',
    },
    {
      matchManagers: [
        'github-actions',
      ],
      matchUpdateTypes: [
        'digest',
      ],
      enabled: false,
    },
    {
      matchDatasources: [
        'custom.claude-code',
      ],
      minimumReleaseAge: '0 days',
      sourceUrl: 'https://github.com/anthropics/claude-code',
    },
  ],
}
