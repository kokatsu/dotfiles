{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux-settings.schema.json",
  "schemaVersion": 1,

  "automation": {
    "claudeCodeIntegration": true
  },

  // Karabiner: з‰©зђ†Ctrlв†”Cmdе…Ґж›ї + г‚їгѓјгѓџгѓЉгѓ«гЃ§Commandв†’Control
  // зµђжћњ: г‚їгѓјгѓџгѓЉгѓ«г‚ўгѓ—гѓЄгЃ§гЃЇ cmd+ гЃЊе€°йЃ”дёЌиѓЅ в†’ ctrl+/opt+ гЃ«гѓЄгѓћгѓѓгѓ—
  // WezTermдє’жЏ›: PRIMARY=CTRL, SECONDARY=ALT

  "shortcuts": {
    "bindings": {
      // App
      "openSettings": "ctrl+,",
      "reloadConfiguration": "ctrl+shift+,",
      "commandPalette": "ctrl+shift+p",
      "newWindow": "ctrl+shift+n",
      "quit": "ctrl+q",

      // Workspaces
      "toggleSidebar": "ctrl+b",
      "newTab": "ctrl+n",
      "openFolder": "ctrl+o",
      "closeWorkspace": "ctrl+shift+w",
      "renameWorkspace": "opt+r",
      "selectWorkspaceByNumber": "opt+1",
      "goToWorkspace": "ctrl+p",
      "nextSidebarTab": "ctrl+opt+]",
      "prevSidebarTab": "ctrl+opt+[",

      // Surfaces (tabs) вЂ” е‰ЌеѕЊз§»е‹•гЃЇ Ghostty keybind (ctrl+tab/ctrl+shift+tab) гЃ§е‹•дЅњ
      "newSurface": "ctrl+t",
      "closeTab": "opt+w",
      "renameTab": "ctrl+shift+r",

      // Split Panes
      "splitRight": "ctrl+s",
      "splitDown": "ctrl+shift+s",
      "focusLeft": "opt+\u2190",
      "focusRight": "opt+\u2192",
      "focusUp": "opt+\u2191",
      "focusDown": "opt+\u2193",
      "toggleSplitZoom": "ctrl+z",

      // Browser
      "openBrowser": "ctrl+shift+l",
      "focusBrowserAddressBar": "ctrl+l",

      // Find
      "find": "ctrl+f",
      "findNext": "ctrl+g",
      "hideFind": "ctrl+shift+f",
      "useSelectionForFind": "ctrl+e",

      // Notifications
      "showNotifications": "ctrl+i",
      "jumpToUnread": "ctrl+shift+u",

      // Misc
      "toggleFullScreen": "opt+f",
      "toggleTerminalCopyMode": "ctrl+shift+x"
    }
  }
}
