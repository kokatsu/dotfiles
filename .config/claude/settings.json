{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_INSTALLATION_CHECKS": "1"
  },
  "alwaysThinkingEnabled": true,
  "includeCoAuthoredBy": false,
  "respectGitignore": false,
  "fileSuggestion": {
    "type": "command",
    "command": "~/.config/claude/file-suggestion.sh"
  },
  "statusLine": {
    "type": "command",
    "command": "cc-statusline",
    "padding": 0
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmux claude-hook session-start 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cmux claude-hook stop 2>/dev/null; [ \"$(uname)\" = \"Darwin\" ] && terminal-notifier -title 'Claude Code' -message 'タスクが完了しました' -sound Glass -activate com.cmuxterm.app || true"
          },
          {
            "type": "command",
            "command": "~/.config/claude/hooks/session-logger.ts"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/run-deno-hook.sh ~/.config/claude/hooks/skill-tracker.ts",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/check-banned-commands.sh"
          },
          {
            "type": "command",
            "if": "Bash(gh api *)",
            "command": "~/.config/claude/hooks/gh-api-guard.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/check-managed-paths.sh"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/run-deno-hook.sh ~/.config/claude/hooks/skill-tracker.ts",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/pre-compact-handover.ts"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/run-deno-hook.sh ~/.config/claude/hooks/instructions-tracker.ts",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "cmux claude-hook notification 2>/dev/null; [ \"$(uname)\" = \"Darwin\" ] && terminal-notifier -title 'Claude Code' -message '権限の承認が必要です' -sound Glass -activate com.cmuxterm.app || true"
          }
        ]
      }
    ]
  }
}
